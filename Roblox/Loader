VerifyBtn.MouseButton1Click:Connect(function()
    local input = KeyInput.Text
    if input == "" then
        StatusText.Text = "Please enter a key!"
        StatusText.TextColor3 = Color3.fromRGB(231, 76, 60)
        return
    end

    StatusText.Text = "Checking key securely..."
    StatusText.TextColor3 = Color3.fromRGB(241, 196, 15)
    VerifyBtn.Text = "..."
    
    local isValid, errMsg = pcall(function()
        KeyAuthAPI:License(input)
    end)
    
    if isValid then
        StatusText.Text = "Key Verified! Loading..."
        StatusText.TextColor3 = Color3.fromRGB(46, 204, 113)
        VerifyBtn.Text = "Success"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(39, 174, 96)
        
        task.wait(1)
        KeyUI:Destroy() 
        LoadMainScript() 
    else
        StatusText.Text = "Invalid Key / Expired / HWID Mismatch!"
        StatusText.TextColor3 = Color3.fromRGB(231, 76, 60)
        VerifyBtn.Text = "Verify Key"
    end
end)

