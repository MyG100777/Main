repeat task.wait() until game:IsLoaded()
repeat task.wait() until game.Players.LocalPlayer

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

repeat task.wait() until workspace:FindFirstChildOfClass("Camera")

task.wait(1)

local DiscordLink = "https://discord.gg/JyMPreZ7"

local SupportedGames = {
    [14807448145] = "https://raw.githubusercontent.com/MyG100777/Main/refs/heads/main/Roblox/Games/ThaibanCity"
}

local scriptUrl = SupportedGames[game.PlaceId]

if not scriptUrl then
    LocalPlayer:Kick("❌ Map นี้ยังไม่รองรับ GzusX")
    return
end

pcall(function()
    if setclipboard then
        setclipboard(DiscordLink)
    end
end)

pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification",{
        Title = "GzusX Loader",
        Text = "Loading Script...",
        Duration = 5
    })
end)

local success = false
local tries = 0
local maxTries = 3

while not success and tries < maxTries do
    tries = tries + 1 

    local ok, result = pcall(function()
        return game:HttpGet(scriptUrl)
    end)

    if ok and result then
        success = true

        local runSuccess, err = pcall(function()
            loadstring(result)()
        end)

        if not runSuccess then
            warn("Script Runtime Error:", err)
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification",{
                    Title = "❌ Script Error",
                    Text = tostring(err),
                    Duration = 15
                })
            end)
        end
    else
        warn("Load attempt "..tries.." failed")
        task.wait(2)
    end
end

if not success then
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification",{
            Title = "❌ Loader Failed",
            Text = "โหลดสคริปไม่สำเร็จ โปรดเช็คเน็ตหรือตัวรันของคุณ",
            Duration = 5
        })
    end)
end
