local function LoadMainScript()
    local success, err = pcall(function()
        loadstring(game:HttpGet(scriptUrl))()
    end)
    if not success then
        LocalPlayer:Kick("❌ เกิดข้อผิดพลาดในการโหลดสคริปต์: " .. tostring(err))
    end
end


