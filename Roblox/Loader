local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local DiscordLink = "https://discord.gg/JyMPreZ7"
local SupportedGames = {
    [14807448145] = "https://raw.githubusercontent.com/MyG100777/Main/refs/heads/main/Roblox/Games/ThaibanCity"
}

local scriptUrl = SupportedGames[game.PlaceId]

if scriptUrl then
    pcall(function() setclipboard(DiscordLink) end)
    

    if not game:IsLoaded() then
        game.Loaded:Wait()
    end
    
   
    while not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") do
        task.wait(0.5)
    end
    
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "GzusX Loaded!",
            Text = "คัดลอกลิงก์ Discord ให้แล้ว! เข้า Discord เผื่อติดตามข่าวสาร Script GzusX",
            Duration = 5
        })
    end)
    
    task.wait(0.5)
    
    local ok, err = pcall(function()
        loadstring(game:HttpGet(scriptUrl))()
    end)

    if not ok then
        LocalPlayer:Kick("\n❌ GzusX Error ❌\n\nเกิดข้อผิดพลาดในการรันสคริปต์\n\nรายละเอียด: " .. tostring(err))
    end
else
    LocalPlayer:Kick("แมพนี้ยังไม่รองรับ GzusX")
end
